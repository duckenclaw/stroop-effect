"global":"float sdMoon(vec2 p, float d, float ra, float rb )\n{\n    p.y = abs(p.y);\n    float a = (ra*ra - rb*rb + d*d)/(2.0*d);\n    float b = sqrt(max(ra*ra-a*a,0.0));\n    if( d*(p.x*b-p.y*a) > d*d*max(b-p.y,0.0) )\n          return length(p-vec2(a,b));\n    return max( (length(p          )-ra),\n               -(length(p-vec2(d,0))-rb));\n}","inputs":[{"default":"1.0","label":"2:","name":"in_rb","type":"f"},{"default":"1.0","label":"3:","name":"in_d","type":"f"}],"instance":"","longdesc":"A moon described as a signed distance function","name":"sdMoon","outputs":[{"longdesc":"The moon as a signed distance function","sdf2d":"sdMoon($uv - 0.5 - vec2($cx, $cy), $d*$in_d($uv), $ra, $rb*$in_rb($uv))","shortdesc":"Output","type":"sdf2d"}],"parameters":[{"control":"Rect1.y","default":0.6,"label":"Radius","longdesc":"Radius of the moon","max":1,"min":0,"name":"ra","step":0.01,"type":"float"},{"control":"Radius11.r","default":0.5,"label":"Inner Radius","longdesc":"Radius of the inner circle","max":1,"min":0,"name":"rb","step":0.01,"type":"float"},{"control":"Radius1.r","default":0.4,"label":"Distance","longdesc":"Distance of the inner circle away from the origin","max":1,"min":0,"name":"d","step":0.01,"type":"float"},{"control":"P1.x","default":0.2,"label":"Center X","longdesc":"The position of the center on the X axis","max":0.5,"min":-0.5,"name":"cx","shortdesc":"Center.x","step":0.01,"type":"float"},{"control":"P1.y","default":-0.25,"label":"Center Y","longdesc":"The position of the center on the Y axis","max":0.5,"min":-0.5,"name":"cy","shortdesc":"Center.y","step":0.01,"type":"float"}],"shortdesc":"sdMoon"}},{"name":"uniform_greyscale_3","type":"uniform_greyscale","parameters":{"color":0.28},"node_position":{"x":-140,"y":1860},"seed_int":0},{"name":"sdrotate","type":"sdrotate","parameters":{"a":90},"node_position":{"x":360,"y":1760},"seed_int":0},{"name":"shader_7","type":"shader","parameters":{"mode":0,"value":1,"fromMin":0,"fromMax":1,"toMin":0.335,"toMax":1,"cla